{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "innerbloom://marketing/cmo-input-v1",
  "title": "Innerbloom CMO Input v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "period", "business_context", "strategy_memory", "analytics", "previous_campaigns", "available_assets", "operational_constraints", "source_manifest"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_period", "previous_period", "timezone", "target_post_count", "analysis_window"],
      "properties": {
        "current_period": {"$ref": "#/$defs/periodKey"},
        "previous_period": {"$ref": "#/$defs/periodKey"},
        "timezone": {"type": "string", "minLength": 1},
        "target_post_count": {"type": "integer", "minimum": 1, "maximum": 100},
        "analysis_window": {"$ref": "#/$defs/dateWindow"}
      }
    },
    "business_context": {"$ref": "#/$defs/freeObject"},
    "strategy_memory": {"$ref": "#/$defs/freeObject"},
    "analytics": {"$ref": "#/$defs/freeObject"},
    "previous_campaigns": {"type": "array", "items": {"type": "object"}},
    "available_assets": {"$ref": "#/$defs/freeObject"},
    "operational_constraints": {"$ref": "#/$defs/freeObject"},
    "source_manifest": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_type", "source_path_or_id", "captured_at"],
        "properties": {
          "source_type": {"enum": ["repo_file", "database_snapshot", "analytics_sync", "manual_input", "asset_manifest"]},
          "source_path_or_id": {"type": "string", "minLength": 1},
          "captured_at": {"type": "string", "format": "date-time"},
          "checksum": {"type": ["string", "null"]}
        }
      }
    }
  },
  "$defs": {
    "periodKey": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
    "dateWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_date", "end_date"],
      "properties": {
        "start_date": {"type": "string", "format": "date"},
        "end_date": {"type": "string", "format": "date"}
      }
    },
    "freeObject": {"type": "object"}
  }
}